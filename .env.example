# Bicho PR Reviewer — configuration reference.
#
# All settings are read from the environment with the BICHO_ prefix; nested sections use a double
# underscore (__) delimiter. Copy to `.env` for local runs. NEVER commit real secrets — the private
# key and API keys belong in your host's / Railway's secret store, not in git.

# Runtime
BICHO_ENVIRONMENT=local          # local | test | production
BICHO_LOG_LEVEL=INFO
# BICHO_JSON_LOGS=                # unset => JSON in production, human-readable elsewhere

# GitHub App (create an App, install it, download the private key)
BICHO_GITHUB__APP_ID=
BICHO_GITHUB__PRIVATE_KEY=       # PEM contents (single env var; keep newlines)
BICHO_GITHUB__INSTALLATION_ID=
BICHO_GITHUB__API_BASE=https://api.github.com
BICHO_GITHUB__WEBHOOK_SECRET=    # shared secret configured on the App's webhook

# Model providers — configure as many OpenAI-compatible endpoints as you want; ACTIVE selects one.
# Adding a model later (Gemini, OpenAI, a local proxy) is a new PROVIDERS__<NAME>__* block plus
# flipping ACTIVE — you never swap keys.
BICHO_LLM__ACTIVE=minimax
BICHO_LLM__PROVIDERS__MINIMAX__API_KEY=
BICHO_LLM__PROVIDERS__MINIMAX__BASE_URL=https://api.minimax.io/v1
BICHO_LLM__PROVIDERS__MINIMAX__MODEL=minimax-m3
BICHO_LLM__PROVIDERS__MINIMAX__TIMEOUT_SECONDS=60
# BICHO_LLM__PROVIDERS__GEMINI__API_KEY=
# BICHO_LLM__PROVIDERS__GEMINI__BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# BICHO_LLM__PROVIDERS__GEMINI__MODEL=gemini-2.0-flash

# Deterministic scanners (Semgrep CE must be on PATH when enabled)
BICHO_SCANNER__SEMGREP_ENABLED=true
BICHO_SCANNER__SEMGREP_CONFIG=resources/semgrep
BICHO_SCANNER__SEMGREP_TIMEOUT_SECONDS=60
BICHO_SCANNER__PIP_AUDIT_ENABLED=true    # needs outbound network (vulnerability DB)
BICHO_SCANNER__PIP_AUDIT_TIMEOUT_SECONDS=60
